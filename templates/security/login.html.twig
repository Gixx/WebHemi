{% extends 'layout.html.twig' %}

{% block title %}Sign in{% endblock %}

{% block body %}
    <main style="max-width: 420px; margin: 48px auto; padding: 24px; border: 1px solid #ddd; border-radius: 8px;">
        <h1 style="margin: 0 0 20px 0;">Admin login</h1>

        {% if error %}
            <div style="margin-bottom: 16px; color: #b00020;">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {{ form_start(loginForm) }}
            <div style="margin-bottom: 12px;">
                {{ form_label(loginForm._username) }}
                {{ form_widget(loginForm._username) }}
            </div>
            <div style="margin-bottom: 12px;">
                {{ form_label(loginForm._password) }}
                {{ form_widget(loginForm._password) }}
            </div>
            {{ form_widget(loginForm._csrf_token) }}
            <button type="submit">Sign in</button>
        {{ form_end(loginForm) }}
    </main>
{% endblock %}
