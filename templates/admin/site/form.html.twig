{% extends "admin/base.html.twig" %}

{% block page_title %}{{ title }}{% endblock %}

{% block content %}
    <form method="POST">
        <div class="form-group">
            <label for="slug">Slug</label>
            <input type="text" id="slug" name="slug" value="{{ site.slug }}" {% if site.id %}readonly{% endif %} required>
        </div>

        <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" value="{{ site.name }}" required>
        </div>

        {% if site.id %}
            <div class="form-group">
                <label for="isEnabled">
                    <input type="checkbox" id="isEnabled" name="isEnabled" value="1" {% if site.isEnabled %}checked{% endif %}>
                    Enabled
                </label>
            </div>
        {% else %}
            <input type="hidden" name="isEnabled" value="1">
        {% endif %}

        <div class="btn-group">
            <button type="submit" class="btn btn-primary">{{ site.id ? 'Update' : 'Create' }}</button>
            <a href="{{ path('admin_site_list') }}" class="btn" style="background-color: #95a5a6; color: white; text-decoration: none;">Cancel</a>
        </div>
    </form>
{% endblock %}
