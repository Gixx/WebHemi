{% extends "admin/base.html.twig" %}

{% block page_title %}{{ title }}{% endblock %}

{% block content %}
    <form method="POST" style="max-width: 560px;">
        <div class="form-group">
            <label for="name">Name <small style="font-weight:normal; color:#888;">(e.g. article.edit)</small></label>
            <input type="text" id="name" name="name" value="{{ permission.name }}" required>
        </div>

        <div class="form-group">
            <label for="label">Label</label>
            <input type="text" id="label" name="label" value="{{ permission.label }}" required>
        </div>

        <div class="btn-group">
            <button type="submit" class="btn btn-primary">{{ permission.id ? 'Update' : 'Create' }}</button>
            <a href="{{ path('admin_permission_list') }}" class="btn" style="background-color: #95a5a6; color: white; text-decoration: none;">Cancel</a>
        </div>
    </form>
{% endblock %}
