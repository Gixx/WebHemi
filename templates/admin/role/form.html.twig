{% extends "admin/base.html.twig" %}

{% block page_title %}{{ title }}{% endblock %}

{% block content %}
    <form method="POST" style="max-width: 640px;">
        <div class="form-group">
            <label for="name">Name <small style="font-weight:normal; color:#888;">(e.g. ROLE_EDITOR)</small></label>
            <input type="text" id="name" name="name" value="{{ role.name }}" required>
        </div>

        <div class="form-group">
            <label for="label">Label</label>
            <input type="text" id="label" name="label" value="{{ role.label }}" required>
        </div>

        <div class="form-group">
            <label>Permissions</label>
            {% if allPermissions is empty %}
                <p style="color: #888;">No permissions available yet. <a href="{{ path('admin_permission_create') }}">Create one</a>.</p>
            {% else %}
                <div style="max-height: 240px; overflow-y: auto; border: 1px solid #ddd; border-radius: 4px; padding: 10px;">
                    {% for permission in allPermissions %}
                        <label style="font-weight: normal; display: flex; align-items: center; gap: 8px; padding: 4px 0; cursor: pointer;">
                            <input type="checkbox" name="permissions[]" value="{{ permission.id }}"
                                {% if role.permissions is defined and permission in role.permissions %}checked{% endif %}>
                            <code>{{ permission.name }}</code> — {{ permission.label }}
                        </label>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="btn-group">
            <button type="submit" class="btn btn-primary">{{ role.id ? 'Update' : 'Create' }}</button>
            <a href="{{ path('admin_role_list') }}" class="btn" style="background-color: #95a5a6; color: white; text-decoration: none;">Cancel</a>
        </div>
    </form>
{% endblock %}
